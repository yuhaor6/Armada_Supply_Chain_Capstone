p_ci(x):\n","        if len(x) < 2:\n","            return pd.Series({'ci_lower': np.nan, 'ci_upper': np.nan})\n","        means = [np.random.choice(x.values, size=len(x), replace=True).mean() for _ in range(n_bootstrap)]\n","        return pd.Series({'ci_lower': np.percentile(means, 2.5), 'ci_upper': np.percentile(means, 97.5)})\n","\n","    stats = (\n","        data.groupby('DESTINATION_REGION', as_index=False)\n","        .agg(\n","            n_loads=('predicted_prob', 'size'),\n","            mean_predicted_prob=('predicted_prob', 'mean'),\n","            actual_acceptance_rate=('carrier_accepted', 'mean')\n","        )\n","    )\n","\n","    ci_df = data.groupby('DESTINATION_REGION')['predicted_prob'].apply(bootstrap_ci).unstack().reset_index()\n","    stats = stats.merge(ci_df, on='DESTINATION_REGION')\n","\n","    stats = stats[stats['n_loads'] >= min_n].copy()\n","    stats['rank'] = stats['mean_predicted_prob'].rank(ascending=False).astype(int)\n","    stats['prediction_error'] = stats['actual_acceptance_rate'] - stats['mean_predicted_prob']\n","    stats['abs_error'] = stats['prediction_error'].abs()\n","    return stats.sort_values('rank')\n","\n","def print_market_stats(stats, title):\n","    print(f\"\\n{title}\")\n","    print(stats[['rank', 'DESTINATION_REGION', 'n_loads', 'mean_predicted_prob', 'ci_lower', 'ci_upper', 'actual_acceptance_rate', 'prediction_error']].to_string(index=False))\n","\n","    # Validation metrics\n","    corr = stats['mean_predicted_prob'].corr(stats['actual_acceptance_rate'])\n","    mae = stats['abs_error'].mean()\n","    mean_bias = stats['prediction_error'].mean()\n","\n","    print(f\"\\nValidation Metrics:\")\n","    print(f\"  Correlation (predicted vs actual): {corr:.3f}\")\n","    print(f\"  Mean Absolute Error: {mae:.3f}\")\n","    print(f\"  Mean Bias (actual - predicted): {mean_bias:+.3f}\")  # positive = underprediction\n","\n","# All data\n","market_all = get_market_stats_bootstrap(df_full)\n","print_market_stats(market_all, \"ALL DATA - Market Ranking\")\n","\n","# October only\n","df_october = df_full[df_full['month'] == 10]\n","market_october = get_market_stats_bootstrap(df_october)\n","print_market_stats(market_october, \"OCTOBER - Market Ranking\")\n","\n","# CLASS1 carriers only\n","df_class1 = df_full[df_full['CARRIER_CLASS_CD'] == 'CLASS1']\n","market_class1 = get_market_stats_bootstrap(df_class1)\n","print_market_stats(market_class1, \"CLASS1 CARRIERS - Market Ranking\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"XGtinodgLMwK","executionInfo":{"status":"ok","timestamp":1765554360134,"user_tz":300,"elapsed":86173,"user":{"displayName":"Michael Zheng","userId":"06010853624711353658"}},"outputId":"4b227b79-01a6-4144-e168-d58068c92f76"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","ALL DATA - Market Ranking\n"," rank DESTINATION_REGION  n_loads  mean_predicted_prob  ci_lower  ci_upper  actual_acceptance_rate  prediction_error\n","    1             WI_MAD      394             0.981000  0.965907  0.991459                0.982234          0.001233\n","    2             ON_TOR      305             0.966515  0.949371  0.982906                0.973770          0.007255\n","    3             FL_JAX      156             0.962564  0.931790  0.987994                0.961538         -0.001026\n","    4             NC_GRE     4291             0.955757  0.949714  0.961529                0.958751          0.002994\n","    5             ON_LON      145             0.955403  0.921069  0.980885                0.965517          0.010114\n","    6             TN_MEM     1019             0.955356  0.942681  0.966820                0.954858         -0.000499\n","    7             MI_RAP    12032             0.952810  0.949457  0.956141                0.960106          0.007296\n","    8             OK_OKC     1425             0.950128  0.939315  0.960799                0.951579          0.001451\n","    9             SC_C